# Formspree form ID for the Contact page.
# Get one at https://formspree.io (free tier = 50 submissions/month).
# The ID is the part after /f/ in your Formspree endpoint URL.
# Example: if your endpoint is https://formspree.io/f/mqkregba, set:
VITE_FORMSPREE_ID=your_form_id_here

# Only needed locally if you still want to run the original Express backend.
# Not required for the Vercel deployment.
DATABASE_URL=postgres://user:password@host:5432/dbname
